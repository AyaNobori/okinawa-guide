<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>OKI TRIP | 宿泊ゲスト限定</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --coral: #FF6B50;
  --coral-dark: #E5513A;
  --teal: #3C8681;
  --teal-dark: #2A6560;
  --text: #222222;
  --sub: #717171;
  --border: #DDDDDD;
  --bg: #F7F7F7;
  --white: #FFFFFF;
  --radius: 16px;
  --shadow: 0 2px 16px rgba(0,0,0,0.10);
}

html { scroll-behavior: smooth; }
body {
  font-family: 'Noto Sans JP', sans-serif;
  background: var(--white);
  color: var(--text);
  max-width: 480px;
  margin: 0 auto;
  padding-bottom: 72px;
}

/* HEADER */
.header {
  position: sticky; top: 0; z-index: 50;
  background: var(--white);
  border-bottom: 1px solid var(--border);
  padding: 14px 20px;
  display: flex; align-items: center; justify-content: space-between;
}
.header-logo { font-size: 22px; font-weight: 800; letter-spacing: -0.5px; }
.header-logo .oki { color: var(--teal); }
.header-logo .trip { color: var(--coral); }
.header-badge {
  display: flex; align-items: center; gap: 6px;
  background: #FFF3F0; border: 1px solid #FFD5CC;
  border-radius: 100px; padding: 5px 12px;
  font-size: 11px; font-weight: 600; color: var(--coral);
}
.header-badge-dot { width: 6px; height: 6px; background: var(--coral); border-radius: 50%; animation: blink 1.8s infinite; }
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.2} }

/* HERO */
.hero {
  position: relative;
  overflow: hidden;
  min-height: 300px;
  display: flex; flex-direction: column; justify-content: flex-end;
  padding: 28px 20px 28px;
  border-bottom: 1px solid var(--border);
  background: linear-gradient(160deg, var(--teal) 0%, var(--teal-dark) 100%);
}
.hero-eyebrow { font-size: 12px; font-weight: 600; color: rgba(255,255,255,0.75); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 8px; position: relative; z-index: 1; }
.hero-title { font-size: 28px; font-weight: 800; color: #fff; line-height: 1.25; margin-bottom: 10px; text-shadow: 0 2px 10px rgba(0,0,0,0.25); position: relative; z-index: 1; }
.hero-desc { font-size: 14px; color: rgba(255,255,255,0.85); line-height: 1.65; margin-bottom: 22px; position: relative; z-index: 1; }
.hero-cta {
  position: relative; z-index: 1;
  display: flex; align-items: center; justify-content: center; gap: 8px;
  background: var(--coral); color: var(--white);
  font-size: 15px; font-weight: 700;
  padding: 16px 24px; border-radius: 12px; text-decoration: none;
  box-shadow: 0 4px 20px rgba(255,107,80,0.45);
  transition: background 0.2s, transform 0.15s;
}
.hero-cta:active { background: var(--coral-dark); transform: scale(0.98); }
.hero-cta svg { width: 18px; height: 18px; }

/* SECTION */
.section { padding: 28px 20px; border-bottom: 1px solid var(--border); }
.section-header { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 18px; }
.section-title { font-size: 19px; font-weight: 800; color: var(--text); }
.section-link { font-size: 13px; font-weight: 600; color: var(--text); text-decoration: underline; text-underline-offset: 2px; }

/* COUPON CARDS */
.cards-scroll {
  margin: 0 -20px; padding: 0 20px 4px;
  display: flex; gap: 14px;
  overflow-x: auto; scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch; scrollbar-width: none;
}
.cards-scroll::-webkit-scrollbar { display: none; }

.coupon-card {
  flex: 0 0 220px;
  background: var(--white);
  border-radius: var(--radius);
  border: 1px solid var(--border);
  overflow: hidden; scroll-snap-align: start;
}

.card-img {
  width: 100%; height: 148px;
  position: relative; overflow: hidden; background: var(--bg);
  display: flex; align-items: center; justify-content: center;
}
.card-img-tag {
  position: absolute; top: 10px; left: 10px;
  background: rgba(255,255,255,0.92);
  color: var(--text); font-size: 10px; font-weight: 700;
  padding: 4px 10px; border-radius: 100px;
  border: 1px solid rgba(0,0,0,0.08); letter-spacing: 0.04em;
}
.coming-badge {
  position: absolute; bottom: 10px; right: 10px;
  background: rgba(34,34,34,0.65); color: rgba(255,255,255,0.92);
  font-size: 9px; font-weight: 700;
  padding: 3px 9px; border-radius: 100px; letter-spacing: 0.05em;
}

.card-body { padding: 14px; }
.card-title { font-size: 14px; font-weight: 700; color: var(--text); margin-bottom: 4px; }
.card-desc { font-size: 12px; color: var(--sub); line-height: 1.55; margin-bottom: 12px; }

.shimmer {
  display: inline-block;
  background: linear-gradient(90deg, #ebebeb 25%, #f5f5f5 50%, #ebebeb 75%);
  background-size: 200% 100%; animation: shimmer 2s infinite;
  border-radius: 6px; color: transparent; user-select: none;
}
@keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }

.card-links { display: flex; gap: 6px; }
.card-link-btn {
  flex: 1; display: flex; align-items: center; justify-content: center; gap: 4px;
  padding: 7px 4px; border-radius: 8px; border: 1px solid var(--border);
  font-size: 10px; font-weight: 600; color: var(--text);
  text-decoration: none; background: var(--white); transition: background 0.15s;
}
.card-link-btn:active { background: var(--bg); }
.card-link-btn svg { width: 12px; height: 12px; }

/* カードSVGイラスト */
.card-img svg { width: 100%; height: 100%; display: block; }

/* CATEGORY */
.cat-scroll { display: flex; gap: 10px; overflow-x: auto; scrollbar-width: none; padding-bottom: 4px; }
.cat-scroll::-webkit-scrollbar { display: none; }
.cat-pill {
  flex: 0 0 auto;
  display: flex; flex-direction: column; align-items: center; gap: 8px;
  padding: 14px 0; width: 76px;
  border-radius: 14px; border: 1.5px solid var(--border);
  background: var(--white); text-decoration: none; color: var(--text);
  transition: border-color 0.15s, background 0.15s;
}
.cat-pill:active { border-color: var(--text); background: var(--bg); }
.cat-pill svg { width: 24px; height: 24px; }
.cat-pill span { font-size: 11px; font-weight: 600; white-space: nowrap; }

/* MAP */
.map-section { padding: 28px 20px; border-bottom: 1px solid var(--border); }
.map-card { border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; }
.map-visual {
  height: 160px; background: #E8F2F1;
  position: relative; display: flex; align-items: center; justify-content: center; overflow: hidden;
}
.map-visual::before {
  content: ''; position: absolute; inset: 0;
  background:
    repeating-linear-gradient(0deg, transparent, transparent 30px, rgba(60,134,129,0.1) 30px, rgba(60,134,129,0.1) 31px),
    repeating-linear-gradient(90deg, transparent, transparent 30px, rgba(60,134,129,0.1) 30px, rgba(60,134,129,0.1) 31px);
}
.map-pin-wrap { position: relative; z-index: 1; display: flex; flex-direction: column; align-items: center; }
.map-pin-head {
  width: 40px; height: 40px; background: var(--coral);
  border-radius: 50% 50% 50% 0; transform: rotate(-45deg);
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 4px 16px rgba(255,107,80,0.4);
}
.map-pin-head svg { transform: rotate(45deg); width: 18px; height: 18px; color: #fff; }
.map-pin-shadow { width: 14px; height: 5px; background: rgba(0,0,0,0.18); border-radius: 50%; margin-top: 3px; filter: blur(2px); }
.map-visual::after {
  content: ''; position: absolute; top: 50%; left: 50%;
  width: 72px; height: 72px;
  border: 2px solid rgba(255,107,80,0.3); border-radius: 50%;
  animation: ping 2.2s ease-out infinite;
}
@keyframes ping {
  0% { transform: translate(-50%,-60%) scale(0.5); opacity: 1; }
  100% { transform: translate(-50%,-60%) scale(2); opacity: 0; }
}
.map-card-body { padding: 18px 18px 20px; }
.map-card-title { font-size: 17px; font-weight: 800; color: var(--text); margin-bottom: 6px; }
.map-card-desc { font-size: 13px; color: var(--sub); line-height: 1.6; margin-bottom: 16px; }
.map-btn {
  display: flex; align-items: center; justify-content: center; gap: 8px;
  background: var(--coral); color: var(--white);
  font-size: 15px; font-weight: 700;
  padding: 16px; border-radius: 12px; text-decoration: none;
  box-shadow: 0 4px 16px rgba(255,107,80,0.3);
  transition: background 0.2s, transform 0.15s;
}
.map-btn:active { background: var(--coral-dark); transform: scale(0.98); }
.map-btn svg { width: 18px; height: 18px; }

/* FOOTER NAV */
.footer-nav {
  position: fixed; bottom: 0; left: 50%; transform: translateX(-50%);
  width: 100%; max-width: 480px;
  background: var(--white); border-top: 1px solid var(--border);
  display: grid; grid-template-columns: repeat(4, 1fr);
  padding: 8px 0 max(8px, env(safe-area-inset-bottom)); z-index: 100;
}
.nav-item {
  display: flex; flex-direction: column; align-items: center; gap: 3px;
  text-decoration: none; color: var(--sub);
  font-size: 10px; font-weight: 600; padding: 6px 4px; transition: color 0.15s;
}
.nav-item.active { color: var(--coral); }
.nav-item svg { width: 22px; height: 22px; }
</style>
</head>
